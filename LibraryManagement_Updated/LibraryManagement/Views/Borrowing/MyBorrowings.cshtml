@model List<LibraryManagement.Models.Borrowing>
@{
    ViewData["Title"] = "My Borrowings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3><i class="fas fa-book-reader me-2 text-primary"></i>My Borrowings</h3>
    <a asp-controller="Book" asp-action="Index" class="btn btn-outline-primary">
        <i class="fas fa-search me-2"></i>Browse Books
    </a>
</div>

@if (TempData["error"] != null)
{
    <div class="alert alert-danger">@TempData["error"]</div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Book Title</th>
                    <th>Author</th>
                    <th>Borrow Date</th>
                    <th>Return Date</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.BorrowingId</td>
                        <td class="fw-semibold">@b.Book.Title</td>
                        <td>@b.Book.Author</td>
                        <td>@b.BorrowDate.ToString("MMM dd, yyyy")</td>
                        <td>@(b.ReturnDate.HasValue ? b.ReturnDate.Value.ToString("MMM dd, yyyy") : "-")</td>
                        <td>
                            @if (b.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Active</span>
                            }
                        </td>
                        <td>
                            @if (!b.IsReturned)
                            {
                                <form asp-action="Return" asp-controller="Borrowing" method="post" style="display:inline">
                                    <input type="hidden" name="borrowingId" value="@b.BorrowingId" />
                                    <button type="submit" class="btn btn-sm btn-success">
                                        <i class="fas fa-undo me-1"></i>Return
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            You haven't borrowed any books yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
