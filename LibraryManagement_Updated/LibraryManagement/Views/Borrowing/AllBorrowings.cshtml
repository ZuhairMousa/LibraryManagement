@model List<LibraryManagement.Models.Borrowing>
@{
    ViewData["Title"] = "All Borrowings";
}

<h3 class="mb-4"><i class="fas fa-list me-2 text-primary"></i>All Borrowings</h3>

<div class="card">
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>User</th>
                    <th>Book</th>
                    <th>Borrow Date</th>
                    <th>Return Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var b in Model)
                {
                    <tr>
                        <td>@b.BorrowingId</td>
                        <td>@b.User.FullName</td>
                        <td class="fw-semibold">@b.Book.Title</td>
                        <td>@b.BorrowDate.ToString("MMM dd, yyyy")</td>
                        <td>@(b.ReturnDate.HasValue ? b.ReturnDate.Value.ToString("MMM dd, yyyy") : "-")</td>
                        <td>
                            @if (b.IsReturned)
                            {
                                <span class="badge bg-success">Returned</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Active</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">No borrowings found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
