@model Book
@{
    ViewData["Title"] = "Delete Book";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-5">
            <h2>Confirm Deletion</h2>
            <h4 class="text-danger">@Model.Title (@Model.Year)</h4>
            <p class="text-muted">by @Model.Author</p>
            <p>Are you sure you want to delete this book? This action cannot be undone.</p>

            <form asp-action="Delete" method="post">
                <input asp-for="BookId" type="hidden" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-2"></i>Delete
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
            </form>
        </div>
    </div>
</div>
