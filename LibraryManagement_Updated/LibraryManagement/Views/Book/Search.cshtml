@model List<Book>
@{
    ViewData["Title"] = "Search Books";
    string searchBy = ViewBag.SearchBy ?? "title";
    string query = ViewBag.Query ?? "";
}

<h3 class="mb-4"><i class="fas fa-search me-2 text-primary"></i>Search Books</h3>

<div class="card p-4 mb-4">
    <form method="get" asp-action="Search" asp-controller="Book" class="row g-3">
        <div class="col-md-3">
            <label class="form-label fw-semibold">Search By</label>
            <select name="searchBy" class="form-select">
                <option value="title" selected="@(searchBy == "title" ? "selected" : null)">Title</option>
                <option value="author" selected="@(searchBy == "author" ? "selected" : null)">Author</option>
                <option value="genre" selected="@(searchBy == "genre" ? "selected" : null)">Genre</option>
            </select>
        </div>
        <div class="col-md-7">
            <label class="form-label fw-semibold">Keyword</label>
            <input type="text" name="query" class="form-control"
                   placeholder="Enter search term..." value="@query" />
        </div>
        <div class="col-md-2 d-flex align-items-end">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-search me-2"></i>Search
            </button>
        </div>
    </form>
</div>

@if (!string.IsNullOrEmpty(query))
{
    <h5 class="mb-3 text-muted">
        Results for "@query" in @searchBy
    </h5>

    @if (Model != null && Model.Any())
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Title</th>
                    <th>Author</th>
                    <th>Genre</th>
                    <th>Year</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td class="fw-semibold">@book.Title</td>
                        <td>@book.Author</td>
                        <td><span class="badge bg-secondary">@book.Genre</span></td>
                        <td>@book.Year</td>
                        <td>
                            @if (book.IsAvailable)
                            {
                                <span class="badge bg-success">Available</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Borrowed</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@book.BookId"
                               class="btn btn-sm btn-outline-primary">View</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>No books found matching your search.
        </div>
    }
}
