@model Book
@{
    string title = ViewBag.Action + " Book";
    ViewData["Title"] = title;
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card p-5">
            <h4 class="fw-bold mb-4">
                <i class="fas fa-book me-2 text-primary"></i>@ViewBag.Action Book
            </h4>

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <input asp-for="BookId" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="Book title" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Author" class="form-label fw-semibold">Author</label>
                    <input asp-for="Author" class="form-control" placeholder="Author name" />
                    <span asp-validation-for="Author" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Genre" class="form-label fw-semibold">Genre</label>
                        <input asp-for="Genre" class="form-control" placeholder="e.g. Fiction" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ISBN" class="form-label fw-semibold">ISBN</label>
                        <input asp-for="ISBN" class="form-control" placeholder="ISBN number" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Year" class="form-label fw-semibold">Year</label>
                        <input asp-for="Year" class="form-control" placeholder="e.g. 2023" />
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-semibold d-block">Availability</label>
                        <div class="form-check form-switch mt-2">
                            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
                            <label asp-for="IsAvailable" class="form-check-label">Available</label>
                        </div>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3"
                              placeholder="Short description..."></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Save
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
