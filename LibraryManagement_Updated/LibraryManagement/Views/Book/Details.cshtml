@model LibraryManagement.Models.Book
@{
    ViewData["Title"] = "Book Details";
    var userId = Context.Session.GetInt32("UserId");
    var userRole = Context.Session.GetString("UserRole");
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card p-5">
            <h4 class="fw-bold mb-1">@Model.Title</h4>
            <p class="text-muted mb-4">by @Model.Author</p>

            <table class="table table-bordered table-striped">
                <tr>
                    <td class="fw-semibold" style="width:35%">Genre</td>
                    <td><span class="badge bg-secondary">@Model.Genre</span></td>
                </tr>
                <tr>
                    <td class="fw-semibold">ISBN</td>
                    <td>@(string.IsNullOrEmpty(Model.ISBN) ? "N/A" : Model.ISBN)</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Year Published</td>
                    <td>@Model.Year</td>
                </tr>
                <tr>
                    <td class="fw-semibold">Status</td>
                    <td>
                        @if (Model.IsAvailable)
                        {
                            <span class="badge bg-success">Available</span>
                        }
                        else
                        {
                            <span class="badge bg-danger">Not Available</span>
                        }
                    </td>
                </tr>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <tr>
                        <td class="fw-semibold">Description</td>
                        <td>@Model.Description</td>
                    </tr>
                }
            </table>

            <div class="d-flex gap-2 mt-2 flex-wrap">
                @if (userRole == "Admin")
                {
                    <a asp-action="Edit" asp-route-id="@Model.BookId" class="btn btn-warning">
                        <i class="fas fa-edit me-2"></i>Edit
                    </a>
                }
                @if (userId != null && Model.IsAvailable)
                {
                    <form asp-action="Borrow" asp-controller="Borrowing" method="post" style="display:inline">
                        <input type="hidden" name="bookId" value="@Model.BookId" />
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-book-reader me-2"></i>Borrow Book
                        </button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back
                </a>
            </div>

            @if (TempData["error"] != null)
            {
                <div class="alert alert-danger mt-3">@TempData["error"]</div>
            }
        </div>

        @if (userId != null)
        {
            <div class="card p-4 mt-4">
                <h5><i class="fas fa-star me-2 text-warning"></i>Rate This Book</h5>
                <form asp-action="Rate" asp-controller="Rating" method="post" class="mt-3">
                    <input type="hidden" name="bookId" value="@Model.BookId" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Stars (1-5)</label>
                        <select name="stars" class="form-select" style="width:150px">
                            <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                            <option value="4">⭐⭐⭐⭐ (4)</option>
                            <option value="3">⭐⭐⭐ (3)</option>
                            <option value="2">⭐⭐ (2)</option>
                            <option value="1">⭐ (1)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Comment</label>
                        <textarea name="comment" class="form-control" rows="2" placeholder="Write your review..."></textarea>
                    </div>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-star me-2"></i>Submit Rating
                    </button>
                </form>
            </div>
        }
    </div>
</div>
