@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col">
        <h2><i class="fas fa-tachometer-alt me-2 text-primary"></i>Dashboard</h2>
        <p class="text-muted">Welcome back, <strong>@Context.Session.GetString("UserName")</strong>
            @if (Context.Session.GetString("UserRole") == "Admin")
            {
                <span class="badge bg-warning text-dark ms-1">Admin</span>
            }
        </p>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card p-4" style="border-left: 4px solid #0d6efd;">
            <div class="d-flex align-items-center">
                <div class="fs-1 text-primary me-3"><i class="fas fa-book"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalBooks</div>
                    <div class="text-muted">Total Books</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-4" style="border-left: 4px solid #198754;">
            <div class="d-flex align-items-center">
                <div class="fs-1 text-success me-3"><i class="fas fa-check-circle"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.AvailableBooks</div>
                    <div class="text-muted">Available Books</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-4" style="border-left: 4px solid #fd7e14;">
            <div class="d-flex align-items-center">
                <div class="fs-1 text-warning me-3"><i class="fas fa-users"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalUsers</div>
                    <div class="text-muted">Registered Users</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-4" style="border-left: 4px solid #dc3545;">
            <div class="d-flex align-items-center">
                <div class="fs-1 text-danger me-3"><i class="fas fa-book-reader"></i></div>
                <div>
                    <div class="fs-3 fw-bold">@ViewBag.TotalBorrowings</div>
                    <div class="text-muted">Active Borrowings</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h5><i class="fas fa-bolt me-2 text-primary"></i>Quick Actions</h5>
            <div class="list-group list-group-flush mt-3">
                <a href="/Book/Index" class="list-group-item list-group-item-action">
                    <i class="fas fa-list me-2"></i>View All Books
                </a>
                <a href="/Book/Search" class="list-group-item list-group-item-action">
                    <i class="fas fa-search me-2"></i>Search Books
                </a>
                <a href="/Borrowing/MyBorrowings" class="list-group-item list-group-item-action">
                    <i class="fas fa-book-reader me-2"></i>My Borrowings
                </a>
                <a href="/Account/Profile" class="list-group-item list-group-item-action">
                    <i class="fas fa-user me-2"></i>View My Profile
                </a>
                <a href="/Account/ChangePassword" class="list-group-item list-group-item-action">
                    <i class="fas fa-key me-2"></i>Change Password
                </a>
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <a href="/Book/Add" class="list-group-item list-group-item-action text-warning fw-semibold">
                        <i class="fas fa-plus me-2"></i>Add New Book (Admin)
                    </a>
                    <a href="/Borrowing/AllBorrowings" class="list-group-item list-group-item-action text-warning fw-semibold">
                        <i class="fas fa-clipboard-list me-2"></i>All Borrowings (Admin)
                    </a>
                }
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card p-4 h-100">
            <h5><i class="fas fa-info-circle me-2 text-primary"></i>Your Permissions</h5>
            <div class="mt-3">
                @if (Context.Session.GetString("UserRole") == "Admin")
                {
                    <div class="alert alert-warning">
                        <i class="fas fa-crown me-2"></i><strong>Admin Account</strong><br />
                        You have full access to manage the library.
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        <i class="fas fa-user me-2"></i><strong>User Account</strong><br />
                        You can browse, borrow, and rate books.
                    </div>
                }
                <ul class="text-muted mt-2">
                    <li>Browse all books ✅</li>
                    <li>Search by title, author, genre ✅</li>
                    <li>Borrow books ✅</li>
                    <li>Return books ✅</li>
                    <li>Rate books ✅</li>
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <li>Add/Edit/Delete books ✅</li>
                        <li>View all borrowings ✅</li>
                    }
                    else
                    {
                        <li>Add/Edit/Delete books ❌ (Admin only)</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
